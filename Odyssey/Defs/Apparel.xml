<Defs>

    <ThingDef Name="Kurin_Vacsuits" ParentName="Kurin_OnSkinBase" Abstract="True">
        <recipeMaker>
        <researchPrerequisites>
            <li>Kurin_IndVacsuit</li>
        </researchPrerequisites>
        </recipeMaker>
    </ThingDef>

    <ThingDef ParentName="Kurin_Vacsuits">
    <defName>Kurin_OnSkin_Vacsuit</defName>
    <label>kurin vacsuit</label>
    <description>A vacuum-resisting outer suit for Kurin space explorers. Integrates basic electronics for life support and oxygen generation.</description>
    <generateAllowChance>0</generateAllowChance>
    <techLevel>Spacer</techLevel>
    <graphicData>
      <texPath>Kurin/Apparel/OnSkin/Vacsuit_Industrial/Texture</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>0.9</drawSize>
    </graphicData>
    <statBases>
      <WorkToMake>48000</WorkToMake>
      <MaxHitPoints>180</MaxHitPoints>
      <Mass>12</Mass>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>0.52</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.25</ArmorRating_Blunt>
      <ArmorRating_Heat>0.66</ArmorRating_Heat>
      <Insulation_Cold>90</Insulation_Cold>
      <Insulation_Heat>15</Insulation_Heat>
      <EquipDelay>14</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <MoveSpeed>-1.25</MoveSpeed>
      <VacuumResistance>0.32</VacuumResistance>
    </equippedStatOffsets>
    <thingCategories>
      <li>ApparelArmor</li>
    </thingCategories>
    <tradeTags>
      <li>HiTechArmor</li>
      <li>Armor</li>
    </tradeTags>
    <smeltable>true</smeltable>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <wornGraphicPath>Kurin/Apparel/OnSkin/Vacsuit_Industrial/Texture</wornGraphicPath>
      <layers>
        <li>Middle</li>
        <li>Shell</li>
      </layers>
      <tags>
        <li>Kurin</li>
      </tags>
      <defaultOutfitTags>
        <li>Spacefarer</li>
      </defaultOutfitTags>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
      <soundWear>Wear_PowerArmor</soundWear>
      <soundRemove>Remove_PowerArmor</soundRemove>
    </apparel>
    <thingSetMakerTags>
      <li>RewardStandardMidFreq</li>
    </thingSetMakerTags>
    <costList>
      <ComponentIndustrial>3</ComponentIndustrial>
      <Steel>90</Steel>
      <Plasteel>20</Plasteel>
    </costList>
    <recipeMaker>
      <researchPrerequisite>OrbitalTech</researchPrerequisite>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <displayPriority>235</displayPriority>
      <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
      <workSkill>Crafting</workSkill>
      <effectWorking>Smith</effectWorking>
      <soundWorking>Recipe_Smith</soundWorking>
      <!-- <recipeUsers>
        <li>TableMachining</li>
      </recipeUsers> -->
    </recipeMaker>
  </ThingDef>

    <ThingDef ParentName="ArmorHelmetMakeableBase">
        <defName>Kurin_Overhead_VacsuitHelmet</defName>
        <label>Kurin vacsuit helmet</label>
        <description>A helmet that efficiently recycles the user's oxygen, allowing them to breathe in the vacuum of space for hours at a time. Contains a miniaturized anti-vacuum field to allow the ears to poke out safely. Oxygen production is not infinite, and the wearer must return to reload oxygen periodically.</description>
        <possessionCount>1</possessionCount>
        <generateAllowChance>0</generateAllowChance>
        <techLevel>Spacer</techLevel>
        <graphicData>
        <texPath>Kurin/Apparel/Overhead/Space_Helmet_Industrial/Texture</texPath>
        <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <statBases>
        <WorkToMake>15000</WorkToMake>
        <MaxHitPoints>120</MaxHitPoints>
        <Mass>1.5</Mass>
        <Flammability>0.4</Flammability>
        <ArmorRating_Sharp>0.52</ArmorRating_Sharp>
        <ArmorRating_Blunt>0.24</ArmorRating_Blunt>
        <ArmorRating_Heat>0.66</ArmorRating_Heat>
        <Insulation_Cold>6</Insulation_Cold>
        <Insulation_Heat>4</Insulation_Heat>
        <EquipDelay>4</EquipDelay>
        </statBases>
        <equippedStatOffsets>
        <ToxicEnvironmentResistance>0.8</ToxicEnvironmentResistance>
        <VacuumResistance>0.69</VacuumResistance>
        </equippedStatOffsets>
        <smeltable>true</smeltable>
        <apparel>
        <countsAsClothingForNudity>false</countsAsClothingForNudity>
        <developmentalStageFilter>Child, Adult</developmentalStageFilter>
        <immuneToToxGasExposure>true</immuneToToxGasExposure>
        <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
        <canBeGeneratedToSatisfyToxicEnvironmentResistance>false</canBeGeneratedToSatisfyToxicEnvironmentResistance>
        <canBeDesiredForIdeo>false</canBeDesiredForIdeo>
        <bodyPartGroups>
            <li>FullHead</li>
        </bodyPartGroups>
        <wornGraphicPath>Kurin/Apparel/Overhead/Space_Helmet_Industrial/Texture</wornGraphicPath>
        <layers>
            <li>Overhead</li>
        </layers>
        <tags>
            <li>Kurin</li>
        </tags>
        <forceEyesVisibleForRotations>
            <li>1</li>
            <li>2</li>
            <li>3</li>
        </forceEyesVisibleForRotations>
        <defaultOutfitTags>
            <li>Spacefarer</li>
        </defaultOutfitTags>
        </apparel>
        <tradeTags>
            <li>HiTechArmor</li>
            <li>Armor</li>
        </tradeTags>
        <thingSetMakerTags>
        <li>RewardStandardMidFreq</li>
        </thingSetMakerTags>
        <costList>
        <ComponentIndustrial>2</ComponentIndustrial>
        <Steel>40</Steel>
        </costList>
        <recipeMaker>
        <researchPrerequisite>OrbitalTech</researchPrerequisite>
        <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
        <displayPriority>237</displayPriority>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <workSkill>Crafting</workSkill>
        <effectWorking>Smith</effectWorking>
        <soundWorking>Recipe_Smith</soundWorking>
        <!-- <recipeUsers>
            <li>TableMachining</li>
        </recipeUsers> -->
        </recipeMaker>
    </ThingDef>

